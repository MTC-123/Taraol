{
  "alert": "xconv-loop-detected",
  "alert_type": "LOGS_BASED_ALERT",
  "severity": "critical",
  "version": "v5",
  "rule_type": "threshold_rule",
  "eval_window": "30s",
  "frequency": "10s",
  "description": "Cross-conversation loop on edge=$edge; count={{$value}}",
  "summary": "Agent mesh cross-conversation loop: $edge",
  "labels": {
    "amr.enforcement": "controller"
  },
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "graph",
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "signal": "logs",
            "stepInterval": 60,
            "aggregations": [{"expression": "count()", "alias": "count"}],
            "filter": {"expression": "signal = 'xconv_loop_detected'"},
            "groupBy": ["edge"]
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [{"name": "critical", "target": 0, "op": "1", "matchType": "1", "channels": ["agentmesh-controller"]}]
    }
  },
  "evaluation": {"kind": "rolling", "spec": {"evalWindow": "30s", "frequency": "10s", "matchType": "at_least_once"}},
  "notification_settings": {"group_by": ["edge"], "use_policy": true}
}
