{
  "alert": "loop-detected",
  "alert_type": "LOGS_BASED_ALERT",
  "severity": "critical",
  "version": "v5",
  "rule_type": "threshold_rule",
  "eval_window": "1m0s",
  "frequency": "1m0s",
  "description": "Pause candidate: conversation=$conversation_id edge=$edge trace=$trace_id; count={{$value}}",
  "summary": "Agent mesh loop detected for $conversation_id",
  "labels": {
    "amr.enforcement": "controller"
  },
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "graph",
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "signal": "logs",
            "stepInterval": 60,
            "aggregations": [{"expression": "count()", "alias": "count"}],
            "filter": {"expression": "signal = 'loop_detected'"},
            "groupBy": ["conversation_id", "edge", "trace_id"]
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [{"name": "critical", "target": 0, "op": "1", "matchType": "1", "channels": ["agentmesh-controller"]}]
    }
  },
  "evaluation": {"kind": "rolling", "spec": {"evalWindow": "1m0s", "frequency": "1m0s", "matchType": "at_least_once"}},
  "notification_settings": {"group_by": ["conversation_id", "edge", "trace_id"], "use_policy": true}
}
