{
  "alert": "budget-exceeded",
  "alert_type": "LOGS_BASED_ALERT",
  "severity": "warning",
  "version": "v5",
  "rule_type": "threshold_rule",
  "eval_window": "30s",
  "frequency": "10s",
  "description": "Pause writer: conversation=$conversation_id trace=$trace_id; count={{$value}}",
  "summary": "Agent mesh budget exceeded for $conversation_id",
  "labels": {
    "amr.enforcement": "controller"
  },
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "graph",
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "signal": "logs",
            "stepInterval": 60,
            "aggregations": [{"expression": "count()", "alias": "count"}],
            "filter": {"expression": "signal = 'budget_exceeded'"},
            "groupBy": ["conversation_id", "trace_id"]
          }
        }
      ]
    },
    "selectedQueryName": "A",
    "thresholds": {
      "kind": "basic",
      "spec": [{"name": "warning", "target": 0, "op": "1", "matchType": "1", "channels": ["agentmesh-controller"]}]
    }
  },
  "evaluation": {"kind": "rolling", "spec": {"evalWindow": "30s", "frequency": "10s", "matchType": "at_least_once"}},
  "notification_settings": {"group_by": ["conversation_id", "trace_id"], "use_policy": true}
}
