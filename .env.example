# Generate a unique local value before starting the Compose stack. `make demo`
# generates a throwaway one if this is absent.
SIGNOZ_TOKENIZER_JWT_SECRET=replace-with-a-random-32-byte-secret

# Local OTLP endpoint exposed by the SigNoz collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Required only for Terraform-managed alert provisioning (`make demo-full`). The
# local official SigNoz MCP server can start in HTTP mode without it, but
# requires a supported SigNoz credential to execute queries.
SIGNOZ_API_KEY=
SIGNOZ_URL=http://localhost:8080
SIGNOZ_MCP_URL=http://localhost:8003/mcp
# Optional self-hosted fallback. Compose configures its private equivalent automatically.
SIGNOZ_CLICKHOUSE_URL=

# Agents: fake LLM by default (deterministic tokens/costs, no API key needed).
AMR_LLM=fake
AMR_MODEL=gpt-4.1-mini
# off | on | storm — storm makes the loop breach fast and deterministic.
AMR_LOOP_MODE=off

# Loop watcher: threshold values are intentionally conservative for the local demo.
AMR_LOOP_WINDOW_SEC=30
AMR_LOOP_MAX_REPEATS=3
AMR_BUDGET_USD=0.01
AMR_POLL_INTERVAL_SEC=5
AMR_BUDGET_LOOKBACK_SEC=3600
AMR_SIGNAL_COOLDOWN_SEC=60

# Controller: auto pauses on alert; set to "off" to observe without enforcement.
AMR_ENFORCE=auto
AMR_ALERT_COOLDOWN_SEC=60

# Host port overrides.
AMR_PLANNER_PORT=8000
AMR_CONTROLLER_PORT=8002
SIGNOZ_MCP_PORT=8003

# Demo mode uses a unique conversation and a 90 second verification deadline.
AMR_DEMO_TIMEOUT_SEC=90
